# AI 办公助手 配置模板
# 复制此文件为 .env，填入实际值后重启 App

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 模型 API（OpenAI 兼容接口即可）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# API 地址
# DeepSeek:  https://api.deepseek.com/v1
# Ollama:    http://localhost:11434/v1
# vLLM:      http://IP:8000/v1
OA_OLLAMA_URL=https://api.deepseek.com/v1

# 模型名称
# DeepSeek:  deepseek-chat
# Ollama:    qwen2.5
# vLLM:      部署时注册的名称
OA_OLLAMA_MODEL=deepseek-chat

# API Key
# DeepSeek:  你的 API Key
# Ollama:    填 ollama（不需要真实 key）
OA_API_KEY=your_api_key_here
